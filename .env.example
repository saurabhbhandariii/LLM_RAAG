# ============================================================================
# ENVIRONMENT CONFIGURATION - Privacy Aware Multi-PDF RAG
# Copy this file to .env and fill in your values
# ============================================================================

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Groq API Key (required for LLM inference)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Ollama Configuration (optional - for local LLM)
# Leave as default if using remote Groq API
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# ============================================================================
# PRIVACY & SECURITY CONFIGURATION
# ============================================================================

# Privacy Level: STRICT, STANDARD, or BASIC
# STRICT:   Maximum privacy - All guards enabled, hashed logging, Llama Guard active
# STANDARD: Balanced - LLM Guard enabled, basic logging, good performance  
# BASIC:    Minimal - Only secrets redaction, fastest performance
PRIVACY_LEVEL=STANDARD

# ============================================================================
# OPTIONAL: ADVANCED SECURITY SETTINGS
# ============================================================================

# LLM Guard Configuration
LLM_GUARD_ENABLED=true
LLM_GUARD_THRESHOLD=0.5

# Llama Guard Configuration (requires transformers, torch)
# Only used in STRICT privacy mode
LLAMA_GUARD_ENABLED=false
LLAMA_GUARD_MODEL=meta-llama/Llama-2-7b-chat-hf

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Violation logging configuration
VIOLATION_LOG_FILE=violations.jsonl
HASH_VIOLATIONS=true
AUDIT_ALL_REQUESTS=false  # Set to true in STRICT mode

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Streamlit specific settings (optional)
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# RAG Configuration
RAG_TOP_K=8  # Number of documents to retrieve per query
RAG_CHUNK_SIZE=400  # Size of text chunks for embedding
RAG_CHUNK_OVERLAP=80  # Overlap between chunks

# ============================================================================
# NOTES
# ============================================================================

# 1. SECURITY: Never commit .env files with real API keys to version control
# 2. LOCAL SETUP: Create .env in the project root directory
# 3. PRODUCTION: Use environment variables set in your deployment platform
# 4. PRIVACY: Review privacy_config.py to understand guard configurations
# 5. COMPLIANCE: Violation logs are stored in violations.jsonl with hashed inputs
